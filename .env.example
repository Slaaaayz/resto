# Copier en .env et ajuster si besoin : cp .env.example .env
# Ces valeurs correspondent aux bases lancees par docker-compose.

# --- App ---
NODE_ENV=development
PORT=3000

# --- PostgreSQL ---
# En local (hors Docker) la base ecoute sur localhost:5432.
POSTGRES_URL=postgresql://resto_user:resto_pass@localhost:5432/restaurant
POSTGRES_DB=restaurant
POSTGRES_USER=resto_user
POSTGRES_PASSWORD=resto_pass

# --- MongoDB ---
MONGO_URL=mongodb://localhost:27017/restaurant

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- Neo4j ---
NEO4J_URL=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASS=resto_pass
